# Iran Market Terminal — Docker deployment settings.
# Copy this file to ".env" (same folder as docker-compose.yml) and fill it in:
#     cp .env.example .env
# docker compose reads it automatically. Never commit the real .env.

# Host port to expose the app on (http://SERVER_IP:PORT)
PORT=4000

# ---- Authentication ----------------------------------------------------------
# Login username (not secret).
AUTH_USERNAME=admin

# Two secrets. Generate them once the image is built:
#   docker compose run --rm terminal python main.py hash-password "your-strong-password"
#   docker compose run --rm terminal python main.py generate-secret
# then paste the printed values here.
AUTH_PASSWORD_HASH=
AUTH_TOKEN_SECRET=

# Dev-only plaintext alternative to AUTH_PASSWORD_HASH (leave empty in production).
# AUTH_PASSWORD=

# ---- Optional ----------------------------------------------------------------
# Require this token on admin/mutating endpoints (leave empty to disable).
# ADMIN_TOKEN=
# Run with synthetic markets (no internet needed) to verify the stack:
# DEMO_MODE=1
