# Iran Market Terminal — copy to ".env" next to docker-compose.yml:
#   cp .env.example .env
# docker compose reads it automatically. Never commit the real .env.

# Host port for the web UI / API
PORT=4000

# ---- PostgreSQL (required) ---------------------------------------------------
# Used by both the `db` service and the app. After `git pull`, `docker compose up`
# creates a fresh database and runs migrations automatically.
POSTGRES_USER=terminal
POSTGRES_PASSWORD=terminal
POSTGRES_DB=terminal
POSTGRES_PORT=5433

# Optional full URL (overrides discrete POSTGRES_* when set on the host for
# non-docker runs). Inside compose the app builds DATABASE_URL automatically.
# DATABASE_URL=postgresql://terminal:terminal@127.0.0.1:5432/terminal

# ---- Authentication ----------------------------------------------------------
AUTH_USERNAME=admin

# Generate after first build:
#   docker compose run --rm terminal python main.py hash-password "your-strong-password"
#   docker compose run --rm terminal python main.py generate-secret
AUTH_PASSWORD_HASH=
AUTH_TOKEN_SECRET=

# Dev-only plaintext (leave empty in production)
# AUTH_PASSWORD=

# ---- Optional ----------------------------------------------------------------
# ADMIN_TOKEN=
# DEMO_MODE=1
