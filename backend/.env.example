# Local (non-docker) backend config — copy to backend/.env
#   cp backend/.env.example backend/.env
#
# Prefer `docker compose up` from the repo root (Postgres + app together).
# Use this file only when running `python main.py` on the host against a
# local Postgres (e.g. the compose `db` service on port 5432).

# ---- PostgreSQL (required) ---------------------------------------------------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=terminal
POSTGRES_PASSWORD=terminal
POSTGRES_DB=terminal
# Or:
# DATABASE_URL=postgresql://terminal:terminal@127.0.0.1:5432/terminal

# ---- Authentication ----------------------------------------------------------
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=
AUTH_TOKEN_SECRET=
# AUTH_PASSWORD=

# HOST=127.0.0.1
# PORT=4000
# DEMO_MODE=1
