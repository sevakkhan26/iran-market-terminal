# Iran Market Terminal — environment configuration
# Copy to backend/.env for local development:   cp .env.example .env
# On Vercel/hosting: set the same variables in the project dashboard instead.
# NEVER commit the real .env file (it is in .gitignore).

# ------------------------------------------------------------------ auth ---
# Login username (not secret, but configurable)
AUTH_USERNAME=admin

# SECRET 1 — password hash. The plaintext password is never stored anywhere.
# Generate the value:   python3 main.py hash-password "your-strong-password"
AUTH_PASSWORD_HASH=

# SECRET 2 — token signing secret (independent from the password).
# Generate the value:   python3 main.py generate-secret
AUTH_TOKEN_SECRET=

# Dev-only alternative to AUTH_PASSWORD_HASH (plaintext, hashed in memory at
# startup). Leave empty in production.
# AUTH_PASSWORD=

# ---------------------------------------------------------------- server ---
# HOST=127.0.0.1
# PORT=4000
# DEMO_MODE=1
# TERMINAL_DATA_DIR=/var/lib/terminal-data
